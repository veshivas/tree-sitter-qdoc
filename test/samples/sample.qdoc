/*!
    \qmltype AbstractButton
    \inqmlmodule QtQuick.Controls
    \brief An abstract base type for interactive buttons.
    \qmlabstract
    \instantiates QQuickAbstractButton
    \since 2.0

    AbstractButton provides the base behavior and appearance for button-like controls.
    Derive from this type to implement custom button types.

    \qmlproperty bool AbstractButton::checked
    \qmldefault

    Whether the button is checked. This is the default property.
*/

/*!
    \qmlvaluetype color
    \inqmlmodule QtQuick
    \brief The color value type refers to an ARGB color value.
    \nativetype QColor

    The \c color type refers to an ARGB color value. It can be specified
    using an SVG color name, a hexadecimal triplet, or \c Qt.rgba().
*/

/*!
    \qmlenum Calculator::Operation
    \qmlenumeratorsfrom Calculator
    \brief The supported arithmetic operations exposed to QML.

    \value Add Addition operation.
    \value Subtract Subtraction operation.
    \value Multiply Multiplication operation.
    \value Divide Division operation.
*/

