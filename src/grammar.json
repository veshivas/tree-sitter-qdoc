            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "FIELD",
                  "name": "span",
                  "content": {
                    "type": "SYMBOL",
                    "name": "cell_span"
                  }
                },
                {
                  "type": "SYMBOL",
                  "name": "command_argument"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "inline_command": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
