{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "qdoc",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "comment"
      }
    },
    "comment": {
      "type": "SYMBOL",
      "name": "block_comment"
    },
    "block_comment": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "/*!"
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "markup"
            }
          },
          {
            "type": "STRING",
            "value": "*/"
          }
        ]
      }
    },
    "markup": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "block_command"
        },
        {
          "type": "SYMBOL",
          "name": "image_command"
        },
        {
          "type": "SYMBOL",
          "name": "inlineimage_command"
        },
        {
          "type": "SYMBOL",
          "name": "command"
        },
        {
          "type": "SYMBOL",
          "name": "link_command"
        },
        {
          "type": "SYMBOL",
          "name": "inline_command"
        },
        {
          "type": "SYMBOL",
          "name": "brace_group"
        },
        {
          "type": "SYMBOL",
          "name": "text"
        }
      ]
    },
    "block_command": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "list_block"
        },
        {
          "type": "SYMBOL",
          "name": "table_block"
        },
        {
          "type": "SYMBOL",
          "name": "raw_block"
        },
        {
          "type": "SYMBOL",
          "name": "legalese_block"
        },
        {
          "type": "SYMBOL",
          "name": "quotation_block"
        },
        {
          "type": "SYMBOL",
          "name": "omit_block"
        },
        {
          "type": "SYMBOL",
          "name": "div_block"
        },
        {
          "type": "SYMBOL",
          "name": "details_block"
        },
        {
          "type": "SYMBOL",
          "name": "if_block"
        }
      ]
    },
    "list_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "\\"
        },
        {
          "type": "STRING",
          "value": "list"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "arg",
              "content": {
                "type": "SYMBOL",
                "name": "block_argument"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "markup"
          }
        },
        {
          "type": "STRING",
          "value": "\\"
        },
        {
          "type": "STRING",
          "value": "endlist"
        }
      ]
    },
    "table_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "\\"
        },
        {
          "type": "STRING",
          "value": "table"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "arg",
              "content": {
                "type": "SYMBOL",
                "name": "block_argument"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "markup"
          }
        },
        {
          "type": "STRING",
          "value": "\\"
        },
        {
          "type": "STRING",
          "value": "endtable"
        }
      ]
    },
    "raw_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "\\"
        },
        {
          "type": "STRING",
          "value": "raw"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "FIELD",
              "name": "arg",
              "content": {
                "type": "SYMBOL",
                "name": "block_argument"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "raw_content_chunk"
          }
        },
        {
          "type": "STRING",
          "value": "\\"
        },
        {
          "type": "STRING",
          "value": "endraw"
        }
      ]
    },
    "legalese_block": {
      "type": "SEQ",
