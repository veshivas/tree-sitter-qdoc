    "image_alt": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "PATTERN",
          "value": "\\{[^}]*\\}"
        }
      }
    },
    "block_argument": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "\\{[^}]*\\}"
            },
            {
              "type": "PATTERN",
              "value": "[^\\s\\\\{}]+"
            }
          ]
        }
      }
    },
    "cell_span": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "PATTERN",
          "value": "\\{[0-9]+,[0-9]+\\}"
        }
      }
    },
    "command_argument": {
      "type": "PATTERN",
      "value": "[^\\s]+"
    },
    "inline_text": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "PATTERN",
            "value": "\\{[^}]*\\}"
          },
          {
            "type": "PATTERN",
            "value": "[^\\s\\\\{}\\n]+"
          }
        ]
      }
    },
    "text": {
      "type": "PATTERN",
      "value": "[^\\\\\\*]+"
