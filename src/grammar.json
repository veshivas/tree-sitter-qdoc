    "if_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "\\"
        },
        {
          "type": "STRING",
          "value": "if"
        },
        {
          "type": "FIELD",
          "name": "condition",
          "content": {
            "type": "SYMBOL",
            "name": "block_argument"
          }
        },
        {
          "type": "FIELD",
          "name": "then",
          "content": {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "markup"
            }
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "\\"
                },
                {
                  "type": "STRING",
                  "value": "else"
                },
                {
                  "type": "FIELD",
                  "name": "else",
                  "content": {
                    "type": "REPEAT",
                    "content": {
                      "type": "SYMBOL",
                      "name": "markup"
                    }
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "\\"
        },
        {
          "type": "STRING",
          "value": "endif"
        }
      ]
    },
    "raw_content_chunk": {
      "type": "PATTERN",
      "value": "[^\\\\]+"
    },
    "command": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "\\"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "command_name"
            },
            {
              "type": "SYMBOL",
              "name": "macro_name"
