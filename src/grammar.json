        },
        {
          "type": "STRING",
          "value": "legalese"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "markup"
          }
        },
        {
          "type": "STRING",
          "value": "\\"
        },
        {
          "type": "STRING",
          "value": "endlegalese"
        }
      ]
    },
    "quotation_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "\\"
        },
        {
          "type": "STRING",
          "value": "quotation"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
