{
  "name": "qdoc",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "comment"
      }
    },
    "comment": {
      "type": "SYMBOL",
      "name": "block_comment"
    },
    "block_comment": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "/*!"
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "markup"
            }
          },
          {
            "type": "STRING",
            "value": "*/"
          }
        ]
      }
    },
    "markup": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "block_command"
        },
        {
          "type": "SYMBOL",
          "name": "image_command"
        },
        {
          "type": "SYMBOL",
          "name": "inlineimage_command"
        },
        {
          "type": "SYMBOL",
          "name": "command"
        },
        {
          "type": "SYMBOL",
          "name": "inline_command"
        },
        {
          "type": "SYMBOL",
          "name": "text"
        }
      ]
    },
    "block_command": {
