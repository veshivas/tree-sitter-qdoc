    "link_command": {
      "type": "PREC_RIGHT",
      "value": 0,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "\\"
          },
          {
            "type": "STRING",
            "value": "l"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "FIELD",
                "name": "hints",
                "content": {
                  "type": "SYMBOL",
                  "name": "link_hints"
                }
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "FIELD",
            "name": "target",
            "content": {
              "type": "SYMBOL",
              "name": "inline_text"
            }
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "FIELD",
                "name": "alias",
                "content": {
                  "type": "SYMBOL",
                  "name": "link_alias"
                }
              },
              {
                "type": "BLANK"
              }
            ]
          }
        ]
      }
    },
    "link_hints": {
      "type": "PATTERN",
      "value": "\\[[^\\]]*\\]"
    },
    "link_alias": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "PATTERN",
          "value": "\\{[^}]*\\}"
        }
      }
    },
